# ─────────────────────────────────────────────────────────────────────────────
# Woxsen RAG Backend – Environment Variables Template
# Copy to .env and fill in the real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# ── Gemini / Google AI ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Redis (set only when using Redis; leave empty for in-memory fallback) ─
REDIS_URL=redis://redis:6379/0

# ── CORS (comma-separated list of allowed origins) ────────────────────────
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5500

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me-too
